# ============================================================
# apps/web 用環境変数
# Vercelの apps/web プロジェクトに設定する
# ============================================================

# PostgreSQL接続文字列（Neon/Supabase から取得）
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# LP URLの生成に使用（本番ドメインを設定）
NEXT_PUBLIC_BASE_URL=https://your-web-domain.vercel.app

# Anthropic Claude API Key（LP自動生成に使用）
ANTHROPIC_API_KEY=sk-ant-api03-...


# ============================================================
# apps/admin 用環境変数
# Vercelの apps/admin プロジェクトに設定する
# ============================================================

# PostgreSQL接続文字列（webと同じDBを使用）
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# NextAuth.js 署名鍵（必須）
# 生成コマンド: openssl rand -base64 32
AUTH_SECRET=your-secret-key-here

# 管理画面ログイン情報（デフォルト: admin / password）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-strong-password-here

# Anthropic Claude API Key（LP自動生成に使用）
ANTHROPIC_API_KEY=sk-ant-api03-...

# LP URLの生成に使用（webアプリのURL）
NEXT_PUBLIC_BASE_URL=https://your-web-domain.vercel.app


# ============================================================
# ローカル開発用（.env.local に記載）
# ============================================================

# SQLiteのパス（未設定時: data/clicks.db）
# DATABASE_PATH=/absolute/path/to/data/clicks.db

# Twitter API v2（SNS自動投稿・取得後に設定）
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_SECRET=
